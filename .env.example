# Connect to your database via connection pooling (e.g. Supabase pgBouncer)
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"

# Direct connection to the database (used for migrations)
DIRECT_URL="postgresql://user:password@host:5432/database"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
ADMIN_EMAILS="admin@fairfieldcenter.org"
AUTH_EMAIL_FROM="no-reply@fairfieldcenter.org"

# Encryption (used by src/util/server/encryption.ts)
ENCRYPTION_PASSWORD="your-encryption-password"
ENCRYPTION_SALT="your-encryption-salt"
