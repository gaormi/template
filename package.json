{
  "name": "nextjs-cloudflare-template",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "c": "lsof -ti :3000 | xargs kill -9",
    "p": "node scripts/dev.js",
    "migrate": "npx prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql",
    "cb": "opennextjs-cloudflare build",
    "cp": "opennextjs-cloudflare build && node scripts/preview.js",
    "cc": "lsof -ti :8787 | xargs kill -9",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.17.3",
    "@prisma/adapter-pg": "^6.10.1",
    "@prisma/client": "^6.10.1",
    "dotenv": "^16.4.7",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "pg": "8.15.6",
    "prisma": "^6.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.3.3",
    "use-debounce": "^10.0.4",
    "use-local-storage-state": "^19.5.0",
    "wrangler": "^4.63.0",
    "zustand": "^5.0.0"
  },
  "resolutions": {
    "pg/pg-cloudflare": "1.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.15.23",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8",
    "eslint-config-next": "^16.1.5",
    "localtunnel": "^2.0.2",
    "postcss": "^8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
