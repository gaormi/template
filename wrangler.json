{
  "main": ".open-next/worker.js",
  "name": "fairfield-center",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "<YOUR_HYPERDRIVE_ID>",
      "localConnectionString": "postgresql://postgres:postgres@localhost:5432/fairfield"
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "fairfield-center"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "fairfield-center-cache"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
